# ══════════════════════════════════════════════════════════════════════
# CONFIGURAZIONE — Biblioteca Scolastica
# Copia questo file in ".env" e compila i valori. NON committare mai il
# file ".env" reale (con i valori veri) in repository pubblici o zip
# condivisi: contiene segreti.
# ══════════════════════════════════════════════════════════════════════

# --- Sicurezza (OBBLIGATORIE) -------------------------------------------
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
BIBLIOTECA_SECRET=

# Genera con: python setup_admin.py
BIBLIOTECA_ADMIN_HASH=

# --- Database ------------------------------------------------------------
# In locale puoi lasciarla vuota: si userà un file SQLite automaticamente.
# In produzione, stringa di connessione Postgres fornita da Neon:
#   postgresql://utente:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=

# --- Google Books (copertine libri) --------------------------------------
# Crea una API Key su https://console.cloud.google.com (Google Books API)
GOOGLE_BOOKS_API_KEY=

# --- Altro -----------------------------------------------------------------
# URL pubblico del frontend (opzionale)
FRONTEND_URL=

# Lista di origini CORS consentite, separate da virgola.
# Se vuota: consente tutte le origini (va bene in sviluppo, da restringere
# in produzione una volta noto l'URL definitivo del frontend).
CORS_ORIGINS=

# Imposta "true" per disattivare lo scheduler delle notifiche (utile in sviluppo/test)
DISABLE_SCHEDULER=false

# ══════════════════════════════════════════════════════════════════════
# NOTA: le notifiche (conferma prestito, promemoria, ritardi, alert prof)
# sono interne al portale — NON vengono inviate per email. Non serve
# nessuna configurazione di servizi email esterni (Brevo, ecc.).
# ══════════════════════════════════════════════════════════════════════
